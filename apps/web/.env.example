# Supabase Configuration
# Get these values from your Supabase project settings: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Optional: Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: PAC Provider Credentials (for SAT validation)
# PAC_PROVIDER_API_KEY=
# PAC_PROVIDER_API_SECRET=

# Optional: Stripe (for payments)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Optional: WhatsApp Integration
# WHATSAPP_API_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=

# ============================================
# Organization Service Configuration
# ============================================

# Encryption Keys (REQUIRED for certificate and PAC credential encryption)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CERTIFICATE_ENCRYPTION_KEY=your_64_character_hex_key_here
PAC_ENCRYPTION_KEY=your_64_character_hex_key_here

# Cloud Storage Configuration (Choose either Cloudflare R2 or AWS S3)

# Option 1: Cloudflare R2 (Recommended - no egress fees)
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=sat-compliance-certificates

# Option 2: AWS S3 (Alternative to R2)
# S3_ACCESS_KEY_ID=your_s3_access_key_id
# S3_SECRET_ACCESS_KEY=your_s3_secret_access_key
# S3_REGION=us-east-1
# S3_BUCKET_NAME=sat-compliance-certificates

# Optional: AWS KMS for advanced key management
# AWS_KMS_KEY_ID=your_kms_key_id
